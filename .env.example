# Supabase (public — exposés au navigateur via NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
# Server-only — JAMAIS de préfixe NEXT_PUBLIC_ (sinon bake dans le bundle client = bypass RLS pour tout le monde).
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxxxxxxxxxxxxxxxxxxxxx
# LinkedIn OAuth (app « LaravelTip » ou autre) — ne jamais committer le secret.
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"
# Optionnel : ex. https://tondomaine.com/api/linkedin/callback (sinon derive de NEXT_PUBLIC_SITE_URL)
LINKEDIN_REDIRECT_URI=http://localhost:2026/api/linkedin/callback
